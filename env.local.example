# =============================================================
# TURNIO — Variables de entorno
# Copiá este archivo como .env.local y completá los valores
# =============================================================

# -------------------------------------------------------------
# NEON (base de datos PostgreSQL serverless)
# Dashboard: https://console.neon.tech
# Proyecto → Connection Details → Connection string
# -------------------------------------------------------------
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Para el MCP de Neon en Claude Code
# Dashboard: https://console.neon.tech → Account → API Keys → New API Key
NEON_API_KEY=napi_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -------------------------------------------------------------
# NEXTAUTH v5
# AUTH_SECRET: generá con: openssl rand -base64 32
# -------------------------------------------------------------
AUTH_SECRET=genera_con_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# -------------------------------------------------------------
# MERCADO PAGO
# Dashboard: https://www.mercadopago.com.ar/developers/panel/app
# Cada tenant guarda su propio mp_access_token en la DB.
# Esta variable es solo para verificar la firma del webhook IPN.
# Generá con: openssl rand -hex 32
# -------------------------------------------------------------
MP_WEBHOOK_SECRET=genera_con_openssl_rand_hex_32

# Credenciales de TEST para el tenant demo (seed de desarrollo)
MP_TEST_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx
MP_TEST_PUBLIC_KEY=APP_USR-xxxxxxxxxxxx

# -------------------------------------------------------------
# GOOGLE CALENDAR API
# Console: https://console.cloud.google.com
# Proyecto → APIs → Google Calendar API → Credenciales → OAuth 2.0
# -------------------------------------------------------------
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback

# -------------------------------------------------------------
# RESEND (emails transaccionales)
# Dashboard: https://resend.com/api-keys
# Gratis: 100 emails/día, 3000/mes
# En dev podés usar: EMAIL_FROM=onboarding@resend.dev
# -------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=onboarding@resend.dev

# -------------------------------------------------------------
# APP
# -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Turnio

# -------------------------------------------------------------
# GITHUB (para el MCP de Claude Code)
# Settings → Developer settings → Personal access tokens → Classic
# Scopes: repo, read:org, workflow
# -------------------------------------------------------------
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
